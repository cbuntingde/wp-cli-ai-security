{
    "name": "wp-ai-security/wp-cli-ai-security",
    "description": "AI-powered security scanning for WordPress plugins and themes - scan before install and audit existing installations",
    "type": "wp-cli-package",
    "license": "MIT",
    "authors": [
        {
            "name": "Your Name",
            "email": "your@email.com"
        }
    ],
    "require": {
        "wp-cli/wp-cli": "^2.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "WPAISecurity\\": "php/"
        },
        "files": ["php/ai-security-command.php"]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "7.4"
        }
    }
}